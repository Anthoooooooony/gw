{
    "theme": "dark",
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/tmp"
            ]
        }
    },
    "env": {
        "FOO": "bar"
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "echo foreign"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Read"
            }
        ]
    }
}
